# Frontend Environment Configuration
# Copy this file to .env and update with your values

# API Base URL
# For local development: http://localhost:8000
# For production: https://your-api-domain.com
# IMPORTANT: Do not include /api/v1 (it is appended by the API client)
REACT_APP_API_URL=http://localhost:8000

# Cold Caller Backend Base URL
# Separate FastAPI service for outbound campaign dialing
# IMPORTANT: Do not include /api/v1
REACT_APP_COLD_CALLER_API_URL=http://localhost:8010

# Disable ESLint plugin warnings
DISABLE_ESLINT_PLUGIN=true
